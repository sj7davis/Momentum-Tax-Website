# ============ Momentum Tax portal + onboarding — environment ============
# Copy to .env for local dev. In Railway, set these as service Variables.
# NEVER commit real values.

# Core
NODE_ENV=production
PORT=3000
PORTAL_BASE_URL=https://momentumtax.com.au      # used in magic links, Stripe redirects, emails

# Postgres (Railway provides DATABASE_URL automatically when you add a PG plugin)
DATABASE_URL=postgres://user:pass@host:5432/db

# Trafft webhook
TRAFFT_WEBHOOK_TOKEN=

# Xero Practice Manager (partner app — see README)
XPM_CLIENT_ID=
XPM_CLIENT_SECRET=
XPM_REFRESH_TOKEN=
XPM_TENANT_ID=
XPM_DEFAULT_STAFF_UUID=
# Optional fallback only — the in-app Service→Template mapping supersedes this:
# XPM_TEMPLATE_MAP={"Individual Tax Return":"ITR Standard"}

# Stripe (memberships)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_AUTOMATIC_TAX=true

# Object storage for the document exchange (Railway Bucket / S3 / R2 / MinIO)
S3_ENDPOINT=https://storage.railway.app
S3_REGION=auto
S3_BUCKET=momentum-portal
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=

# Email delivery (POST target for transactional email). Blank = log to console (dev).
EMAIL_WEBHOOK_URL=
